    <Compile Include="Diagnostics.fsi" />
    <Compile Include="Diagnostics.fs" />
    <Compile Include="Json/JsonWriters.fsi" />
    <Compile Include="Json/JsonWriters.fs" />
    <Compile Include="GenerationManifest.fsi" />
    <Compile Include="GenerationManifest.fs" />
    <Compile Include="LifecycleArtifacts/Internal.fs" />
    <Compile Include="LifecycleArtifacts/ArtifactCodec.fsi" />
    <Compile Include="LifecycleArtifacts/ArtifactCodec.fs" />
    <Compile Include="LifecycleArtifacts/Core.fsi" />
    <Compile Include="LifecycleArtifacts/Core.fs" />
