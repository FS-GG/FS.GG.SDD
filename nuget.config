<!-- nuget.config (repo root) — hermetic: clears inherited sources, declares explicit sources -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="fsgg-local" value="./.fsgg-local-feed" />
  </packageSources>
</configuration>
